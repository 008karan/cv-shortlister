# ── CV data — private, never commit ───────────────────────
jd/*
!jd/.gitkeep

resumes/*
!resumes/.gitkeep

resume/*
!resume/.gitkeep

# ── Generated outputs ──────────────────────────────────────
output/batches/extracted/*
!output/batches/extracted/.gitkeep

output/batches/scores/*
!output/batches/scores/.gitkeep

output/final/*
!output/final/.gitkeep

# ── Runtime state ──────────────────────────────────────────
state/*
!state/.gitkeep

# ── Data security — block candidate/result file types ──────
*.pdf
*.docx
*.doc
*.xlsx
*.xls
*.csv
*.txt

# Always allow placeholders
!**/.gitkeep

# ── Python ─────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/
env/

# ── OS ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Claude Code session data ───────────────────────────────
.claude/
